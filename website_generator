import openai

# Initialize OpenAI API
openai.api_key = "your-openai-api-key"

# Get user input
def generate_website(user_prompt):
    response = openai.Completion.create(
        engine="code-davinci-003",  # AI model
        prompt=f"Generate the HTML, CSS, and JavaScript for: {user_prompt}",
        max_tokens=9999999999999999,
        temperature=0.5
    )
    return response.choices[0].text.strip()

user_input = "Create a responsive portfolio website with a navbar, hero section, and contact form."
generated_code = generate_website(user_input)

# Save the generated website
with open("index.html", "w") as f:
    f.write(generated_code)

print("Website generated successfully!")